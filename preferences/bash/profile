alias ods-rds-postoffice-usw2-2="ods-rds postoffice-production-aurora-usw2-001-02.c1udglz7lmyd.us-west-2.rds.amazonaws.com --user app-owners --profile postoffice-production--ods-rds-app-owners postoffice_production"

