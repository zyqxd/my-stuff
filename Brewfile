# David Zhang's Homebrew Bundle (core)
# Install with: brew bundle
#
# Optional GUI apps live in Brewfile.apps and are installed only if you opt in
# during ./setup.sh.

# CLI Tools
brew "bash"
brew "git"
brew "node"
brew "postgresql@16"
brew "tfenv"
brew "yarn"
brew "openssl@3"

# Interactive Git Tools
brew "lazygit"
brew "git-delta"
brew "fzf"

# Modern Terminal Utilities
brew "bat"
brew "eza"
brew "zoxide"

# Terminal (central to this setup)
cask "iterm2"
